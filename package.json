{
  "name": "deennotes-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/mobile"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "mobile": "npm run start -w mobile",
    "mobile:clear": "npm exec --workspace mobile -- expo start --clear",
    "mobile:icons": "node scripts/export-mobile-brand-icons.cjs",
    "watchman:reset": "watchman watch-del \"$PWD\" 2>/dev/null; watchman watch-project \"$PWD\"",
    "mobile:typecheck": "npm run typecheck -w mobile",
    "mobile:doctor": "npm exec --workspace mobile -- expo-doctor",
    "netlify": "netlify",
    "ntl": "netlify",
    "netlify:status": "netlify status",
    "netlify:sites": "netlify sites:list",
    "netlify:deploy": "netlify deploy",
    "netlify:deploy:prod": "netlify deploy --prod"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@quranjs/api": "^3.2.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "groq-sdk": "^0.8.0",
    "html-to-image": "^1.11.13",
    "next": "^15.1.3",
    "openai": "^4.73.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.10",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.3",
    "netlify-cli": "^26.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9",
    "sharp": "^0.34.5"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
