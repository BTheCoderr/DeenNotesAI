# Optional: copy from repo root `.env` — `app.config.ts` maps `NEXT_PUBLIC_SUPABASE_*` (and optional
# `NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY`) into `EXPO_PUBLIC_*` when the keys below are unset.
EXPO_PUBLIC_NEXT_ORIGIN=http://127.0.0.1:3000
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional — client crash / error breadcrumbs (omit in dev if unused)
EXPO_PUBLIC_SENTRY_DSN=

# Optional — EAS Update / OTA: set after `eas update:configure` (https://u.expo.dev/<project-id>)
EXPO_UPDATES_URL=

# M8 — RevenueCat (iOS App Store subscriptions; required for TestFlight purchase flows)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
# Optional — defaults to "premium" when unset (match RevenueCat dashboard entitlement identifier)
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_PREMIUM=
# Optional — paywall legal links (defaults: https://deennotes.ai/terms and /privacy)
EXPO_PUBLIC_APP_TERMS_URL=
EXPO_PUBLIC_APP_PRIVACY_URL=

# M9 — TestFlight beta mailto inbox for Settings → Send feedback (beta)
EXPO_PUBLIC_BETA_FEEDBACK_EMAIL=