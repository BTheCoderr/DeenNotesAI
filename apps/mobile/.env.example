# Optional: copy from repo root `.env` — `app.config.ts` maps `NEXT_PUBLIC_SUPABASE_*` into `EXPO_PUBLIC_*`.

# ⚠️ EAS **`production`** iOS builds: `app.config.ts` **fails the build** if Supabase URL + anon/publishable key and
# `EXPO_PUBLIC_REVENUECAT_IOS_API_KEY` are missing — mirror those in Expo → Environment variables → **production**.
# `.env` is not uploaded to EAS; local values do not ship in review binaries.

EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Production: must be your deployed Next.js origin (Netlify). Required for account deletion API + generate-note.
EXPO_PUBLIC_NEXT_ORIGIN=https://deennotesai.netlify.app
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional — client crash / error breadcrumbs (omit in dev if unused)
EXPO_PUBLIC_SENTRY_DSN=

# Optional — EAS Update / OTA: set after `eas update:configure` (https://u.expo.dev/<project-id>)
EXPO_UPDATES_URL=

# M8/M9 — RevenueCat (EXPO-managed; real purchases require EAS dev/preview/production builds — not Expo Go)
# Public SDK key from RevenueCat → Apps → Apple app. Use Apple “public” key prefixed `appl_` for TestFlight / App Store.
# Sandbox/TestFlight IAP still works against App Store sandbox; RevenueCat separates test vs prod by key & project wiring.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
# RevenueCat entitlement identifier (dashboard “Entitlements”) — defaults to DeenNotes AI Pro when unset:
# customerInfo.entitlements.active["DeenNotes AI Pro"]
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_PREMIUM=

# Optional — paywall legal links (defaults: https://deennotesai.netlify.app/terms and /privacy)
EXPO_PUBLIC_APP_TERMS_URL=
EXPO_PUBLIC_APP_PRIVACY_URL=

# M9 — TestFlight beta mailto inbox for Settings → Send feedback (beta)
EXPO_PUBLIC_BETA_FEEDBACK_EMAIL=
