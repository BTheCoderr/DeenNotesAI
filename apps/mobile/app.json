{
  "expo": {
    "name": "DeenNotes",
    "slug": "deennotes",
    "scheme": "deennotes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6F4F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.deennotes.app",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "io.deennotes.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F6F4F0"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "DeenNotes uses your location to calculate prayer times for where you are."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": [],
          "enableBackgroundRemoteNotifications": false
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "DeenNotes needs microphone access to record khutbah and reminders on this device only. Audio stays local unless you attach it to a reflection."
        }
      ],
      "@sentry/react-native"
    ]
  }
}
